# ApplyPilot Railway Configuration

# Pipeline Settings
APPLYPILOT_INTERVAL_HOURS=6
APPLYPILOT_MIN_SCORE=7

# LLM Configuration (Z.ai GLM)
LLM_URL=https://api.z.ai/api/coding/paas/v4
LLM_API_KEY=your_zai_api_key_here
LLM_MODEL=glm-4.5

# Claude API Configuration (for auto-apply)
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your_claude_api_key_here
API_TIMEOUT_MS=3000000

# Data Directory
APPLYPILOT_DATA_DIR=/data

# Server Port
PORT=8080
